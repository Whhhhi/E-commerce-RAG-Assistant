# ── 应用 ──
DEBUG=false
HOST=0.0.0.0
PORT=8000

# ── LLM ──
# provider: openai / deepseek / local
#   openai  → 需要 LLM_API_KEY，使用 OpenAI API
#   deepseek → 需要 LLM_API_KEY + LLM_API_BASE=https://api.deepseek.com/v1
#   local   → 连接本地模型服务器（LM Studio / llama.cpp server / ollama），
#             默认 http://127.0.0.1:1234/v1
LLM_PROVIDER=openai
LLM_MODEL_NAME=gpt-4o-mini
LLM_API_KEY=sk-xxxxxxxxxxxxxxxx
LLM_API_BASE=http://127.0.0.1:1234/v1
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2048

# ── Embedding ──
# provider: openai / local
#   openai  → 需要 EMBEDDING_API_KEY
#   local   → 复用 LLM_API_BASE（也可单独指定 EMBEDDING_API_BASE）
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL_NAME=text-embedding-3-small
EMBEDDING_API_KEY=sk-xxxxxxxxxxxxxxxx
EMBEDDING_API_BASE=

# ── Retrieval ──
RETRIEVER_TOP_K=5
RETRIEVER_RRF_K=60

# ── Document Processing ──
CHUNK_SIZE=512
CHUNK_OVERLAP=50
MAX_FILE_SIZE_MB=20
